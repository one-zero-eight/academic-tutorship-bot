{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Bot (debug)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.bot",
      "cwd": "${workspaceFolder}",
      "justMyCode": true,
      "logToFile": true,
      "console": "internalConsole",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "DEBUGPY_LOG_DIR": "${workspaceFolder}/.logs/debugpy"
      }
    }
  ]
}
